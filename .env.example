# ============================================================
# ScriptMesh — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to version control.
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================================

# ---------------------------------------------------------------------------
# Orchestrator
# ---------------------------------------------------------------------------

# REQUIRED: API key that the controller and agents use to authenticate with
# the orchestrator. Must be at least 32 characters. No default accepted.
SCRIPT_MESH_MAIN_KEY=replace-me-with-a-strong-random-secret

# Set to "true" to disable /docs, /redoc, and /openapi.json in production
DISABLE_DOCS=false

# Comma-separated list of origins allowed by CORS (leave empty to disable CORS)
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# How often (seconds) the orchestrator pings registered agents for health
HEALTH_CHECK_INTERVAL=60

# Number of Gunicorn worker processes (set to 2×CPU cores + 1 for production)
WEB_CONCURRENCY=2

# ---------------------------------------------------------------------------
# Agent
# ---------------------------------------------------------------------------

# REQUIRED: Secret key for this agent. Each agent should have a unique key.
# Must be at least 32 characters. No default accepted.
SCRIPT_MESH_AGENT_KEY=replace-me-with-a-strong-random-secret

# URL of the orchestrator that this agent registers with
ORCHESTRATOR_URL=http://localhost:8000

# Publicly reachable URL for this agent (used during registration)
# Defaults to http://<hostname>:5001 if not set
AGENT_URL=http://your-agent-host:5001

# Maximum seconds a triggered script is allowed to run before being killed
SCRIPT_TIMEOUT=60

# ---------------------------------------------------------------------------
# Controller
# ---------------------------------------------------------------------------

# Host and port of the orchestrator (without scheme)
ORCHESTRATOR_HOST=localhost:8000

# http or https
ORCHESTRATOR_SCHEME=http

# Timeout for controller HTTP requests (seconds)
REQUEST_TIMEOUT=10

[flake8]
max-line-length = 100
extend-ignore =
    # Line too long — handled by black
    E501,
    # Whitespace before ':' — conflicts with black
    E203,
    # Line break before binary operator
    W503,
per-file-ignores =
    # Allow unused imports in __init__ files
    __init__.py: F401
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info
